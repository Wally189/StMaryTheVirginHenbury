---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en-GB" data-base-url={import.meta.env.BASE_URL}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/jpeg" href="/images/logo.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cabin:wght@500;600;700&family=Open+Sans:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <script is:inline>
      (() => {
        const baseUrl = document.documentElement.dataset.baseUrl || "/";
        if (!baseUrl || baseUrl === "/") return;

        const basePrefix = baseUrl.endsWith("/") ? baseUrl.slice(0, -1) : baseUrl;

        const withBase = (value) => {
          if (!value || !value.startsWith("/")) return value;
          if (value.startsWith("//")) return value;
          if (value.startsWith(basePrefix + "/") || value === basePrefix) return value;
          return `${basePrefix}${value}`;
        };

        const rewriteSrcset = (srcset) => {
          if (!srcset) return srcset;
          return srcset
            .split(",")
            .map((part) => {
              const trimmed = part.trim();
              if (!trimmed) return trimmed;
              const [url, descriptor] = trimmed.split(/\s+/, 2);
              const nextUrl = withBase(url);
              return descriptor ? `${nextUrl} ${descriptor}` : nextUrl;
            })
            .join(", ");
        };

        const patch = () => {
          document.querySelectorAll("a[href]").forEach((el) => {
            el.setAttribute("href", withBase(el.getAttribute("href")));
          });
          document.querySelectorAll("img[src], iframe[src], script[src], source[src]").forEach((el) => {
            el.setAttribute("src", withBase(el.getAttribute("src")));
          });
          document.querySelectorAll("form[action]").forEach((el) => {
            el.setAttribute("action", withBase(el.getAttribute("action")));
          });
          document.querySelectorAll("link[href]").forEach((el) => {
            el.setAttribute("href", withBase(el.getAttribute("href")));
          });
          document.querySelectorAll("source[srcset], img[srcset]").forEach((el) => {
            el.setAttribute("srcset", rewriteSrcset(el.getAttribute("srcset")));
          });
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", patch);
        } else {
          patch();
        }
      })();
    </script>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <div class="motif-strip" aria-hidden="true"></div>
    <main id="main-content">
      <slot />
    </main>
    <div class="motif-strip" aria-hidden="true"></div>
    <Footer />
  </body>
</html>
