---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const peopleEntries = (await getCollection("people")).sort((a, b) => a.data.order - b.data.order);
const people = await Promise.all(
  peopleEntries.map(async (entry) => {
    const { Content } = await entry.render();
    return { entry, Content };
  }),
);
---

<BaseLayout title="Parish Team | St Mary the Virgin, Henbury" description="People and ministry contacts at St Mary's Henbury.">
  <PageHero
    title="Parish Team"
    intro="People you may meet at St Mary's and who to contact for help."
    image="/images/henbury-church-porch.jpg"
    imageAlt="Stone elevation of St Mary's church"
  />
  <section class="container-width mt-12">
    <div class="mb-6 border-l-2 border-harbour-500 pl-4">
      <p class="text-sm text-nave-700">
        Demo note: portrait placeholders are in use and can be replaced with real staff photos at launch.
      </p>
    </div>
    <ul class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        people.map(({ entry, Content }) => (
          <li class="card">
            <p class="eyebrow">Parish team</p>
            <img
              src={entry.data.photo}
              alt={entry.data.photoAlt}
              class="h-52 w-full border border-nave-300/55 object-cover"
              loading="lazy"
              width="420"
              height="280"
            />
            <h2 class="mt-4 text-2xl">{entry.data.name}</h2>
            <p class="font-semibold text-harbour-900">{entry.data.role}</p>
            <div class="mt-2 text-nave-900">
              <Content />
            </div>
            <div class="mt-3 space-y-1 text-sm text-nave-700">
              {entry.data.phone && <p>{entry.data.phone}</p>}
              {entry.data.email && (
                <p>
                  <a href={`mailto:${entry.data.email}`}>{entry.data.email}</a>
                </p>
              )}
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
