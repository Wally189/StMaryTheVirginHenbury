---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Cookie Policy | St Mary the Virgin, Henbury" description="Cookie policy for St Mary the Virgin, Henbury parish website.">
  <section class="container-width mt-12">
    <article class="section-rule max-w-4xl">
      <p class="eyebrow">Website settings</p>
      <h1 class="mt-2 text-5xl">Cookie policy</h1>
      <p class="mt-4 text-nave-900">
        This site uses only essential cookies needed for basic website operation and, where enabled, Netlify form handling.
      </p>
      <p class="mt-3 text-nave-900">
        We do not use advertising trackers. If analytics are added later, this page will be updated with full details.
      </p>
      <p class="mt-3 text-nave-900">
        Questions can be sent to <a href="mailto:office@stmaryhenbury.org.uk">office@stmaryhenbury.org.uk</a>.
      </p>
    </article>
  </section>
</BaseLayout>
