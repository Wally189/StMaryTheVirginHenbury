---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const page = await getEntry("pages", "welcome");
if (!page) throw new Error("Missing welcome page content.");
const { Content } = await page.render();
---

<BaseLayout title="Welcome | St Mary the Virgin, Henbury" description={page.data.intro}>
  <PageHero
    title={page.data.title}
    intro={page.data.intro}
    image="/images/henbury-church-cross.jpg"
    imageAlt="Churchyard cross with St Mary's in the background"
  />
  <section class="container-width mt-12">
    <div class="grid gap-8 md:grid-cols-2">
      {
        page.data.sections?.map((section) => (
          <article class="section-rule">
            <p class="eyebrow">Welcome guide</p>
            <h2 class="text-2xl">{section.title}</h2>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-nave-900">
              {section.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </section>
  <section class="container-width mt-12">
    <div class="section-rule text-nave-900">
      <Content />
    </div>
  </section>
</BaseLayout>
