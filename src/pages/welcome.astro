---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const page = await getEntry("pages", "welcome");
if (!page) throw new Error("Missing welcome page content.");
const { Content } = await page.render();
---

<BaseLayout title="Welcome | St Mary the Virgin, Henbury" description={page.data.intro}>
  <PageHero
    title={page.data.title}
    intro={page.data.intro}
    image="/images/StMarys.jpg"
    imageAlt="Nave at St Mary the Virgin before Sunday service"
  />
  <section class="container-width mt-10">
    <div class="grid gap-4 md:grid-cols-2">
      {
        page.data.sections?.map((section) => (
          <article class="card">
            <h2 class="text-2xl">{section.title}</h2>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-stone-800">
              {section.items.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </section>
  <section class="container-width mt-8">
    <div class="card text-stone-800">
      <Content />
    </div>
  </section>
</BaseLayout>
