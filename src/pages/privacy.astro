---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Notice | St Mary the Virgin, Henbury" description="Privacy notice for St Mary the Virgin, Henbury parish website.">
  <section class="container-width mt-12">
    <article class="section-rule max-w-4xl">
      <p class="eyebrow">Data protection</p>
      <h1 class="mt-2 text-5xl">Privacy notice</h1>
      <p class="mt-4 text-nave-900">
        St Mary the Virgin, Henbury keeps personal data only for parish administration, pastoral care, and communication about church life.
      </p>
      <p class="mt-3 text-nave-900">
        Contact forms on this site send information to the parish office. We do not sell personal data. You can request access, correction, or deletion by emailing
        <a href="mailto:office@stmaryhenbury.org.uk"> office@stmaryhenbury.org.uk</a>.
      </p>
      <p class="mt-3 text-nave-900">
        For full parish data policy details, contact the Parish Administrator.
      </p>
    </article>
  </section>
</BaseLayout>
