---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateNoWeekday } from "../../utils/dates";

export async function getStaticPaths() {
  const news = (await getCollection("news")).filter((item) => !item.data.draft);
  return news.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

interface Props {
  item: CollectionEntry<"news">;
}

const { item } = Astro.props;
const { Content } = await item.render();
---

<BaseLayout title={`${item.data.title} | St Mary the Virgin, Henbury`} description={item.data.summary}>
  <article class="container-width mt-12 max-w-4xl">
    <div class="section-rule">
      <p class="eyebrow">{formatDateNoWeekday(item.data.date)} | {item.data.category}</p>
      <h1 class="mt-2 text-5xl">{item.data.title}</h1>
    </div>
    {item.data.image && (
      <img
        src={item.data.image.src}
        alt={item.data.image.alt}
        class="mt-6 h-80 w-full border border-nave-300/55 object-cover"
        width="1200"
        height="700"
        loading="lazy"
      />
    )}
    <div class="mt-8 space-y-4 text-lg text-nave-900">
      <Content />
    </div>
    <p class="mt-8">
      <a href="/news">Back to all news</a>
    </p>
  </article>
</BaseLayout>
