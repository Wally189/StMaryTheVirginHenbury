---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateNoWeekday } from "../../utils/dates";

const news = (await getCollection("news"))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="News | St Mary the Virgin, Henbury" description="Latest parish news from St Mary's Henbury.">
  <section class="container-width mt-12">
    <div class="section-rule">
      <p class="eyebrow">Parish updates</p>
      <h1 class="mt-2 text-5xl">News</h1>
    </div>
    <ul class="mt-6 divide-y divide-nave-300/45 border-y border-nave-300/45">
      {
        news.map((item) => (
          <li class="py-6">
            <p class="eyebrow">{formatDateNoWeekday(item.data.date)} | {item.data.category}</p>
            <h2 class="mt-1 text-3xl">{item.data.title}</h2>
            <p class="mt-2 text-nave-900">{item.data.summary}</p>
            <p class="mt-3">
              <a href={`/news/${item.slug}`}>Read article</a>
            </p>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
