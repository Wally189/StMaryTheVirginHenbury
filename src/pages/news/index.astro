---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateNoWeekday } from "../../utils/dates";

const news = (await getCollection("news"))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="News | St Mary the Virgin, Henbury" description="Latest parish news from St Mary's Henbury.">
  <section class="container-width mt-10">
    <h1 class="text-4xl">News</h1>
    <ul class="mt-6 space-y-4">
      {
        news.map((item) => (
          <li class="card">
            <p class="text-sm text-stone-700">{formatDateNoWeekday(item.data.date)} | {item.data.category}</p>
            <h2 class="mt-1 text-3xl">{item.data.title}</h2>
            <p class="mt-2 text-stone-800">{item.data.summary}</p>
            <p class="mt-3">
              <a href={`/news/${item.slug}`}>Read article</a>
            </p>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
