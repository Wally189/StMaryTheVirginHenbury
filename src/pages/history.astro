---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Timeline from "../components/Timeline.astro";

const page = await getEntry("pages", "history");
const timeline = await getEntry("history", "timeline");

if (!page || !timeline) throw new Error("History content missing.");
const { Content } = await page.render();
---

<BaseLayout title="History | St Mary the Virgin, Henbury" description={page.data.intro}>
  <PageHero
    title={page.data.title}
    intro={page.data.intro}
    image="/images/scipioafricanus.jpg"
    imageAlt="Memorial area in St Mary's churchyard"
  />
  <section class="container-width mt-10">
    <article class="card">
      <p class="text-stone-800">{timeline.data.intro}</p>
      <div class="mt-8">
        <Timeline entries={timeline.data.entries} />
      </div>
    </article>
  </section>

  <section class="container-width mt-8">
    <article class="card">
      <h2 class="text-3xl">Churchyard & memorials</h2>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-stone-800">
        {timeline.data.churchyard.map((item) => <li>{item}</li>)}
      </ul>
      <div class="mt-6 text-stone-800">
        <Content />
      </div>
    </article>
  </section>
</BaseLayout>
