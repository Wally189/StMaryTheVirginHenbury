---
import { getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";

const allowed = ["baptisms", "weddings", "funerals"] as const;

export async function getStaticPaths() {
  return allowed.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
if (!slug || !allowed.includes(slug as (typeof allowed)[number])) {
  throw new Error("Invalid life event route.");
}

const page = await getEntry("pages", slug);
if (!page) throw new Error("Missing life event content.");
const { Content } = await page.render();

const imageBySlug: Record<string, { src: string; alt: string }> = {
  baptisms: {
    src: "/images/StMarys.jpg",
    alt: "Stone font at St Mary's church",
  },
  weddings: {
    src: "/images/ameliaedwards.jpg",
    alt: "Historic memorial detail in St Mary's",
  },
  funerals: {
    src: "/images/warmemorial.jpg",
    alt: "Churchyard memorial and yew trees at St Mary's",
  },
};
---

<BaseLayout title={`${page.data.title} | St Mary the Virgin, Henbury`} description={page.data.intro}>
  <PageHero title={page.data.title} intro={page.data.intro} image={imageBySlug[slug].src} imageAlt={imageBySlug[slug].alt} />

  <section class="container-width mt-10 grid gap-8 lg:grid-cols-[1fr_1fr]">
    <article class="card">
      <h2 class="text-3xl">What happens next</h2>
      <ol class="mt-4 list-decimal space-y-2 pl-5 text-stone-800">
        {page.data.nextSteps?.map((step) => <li>{step}</li>)}
      </ol>
      <div class="mt-6 text-stone-800">
        <Content />
      </div>
    </article>

    <article class="card">
      <h2 class="text-3xl">Enquiry form</h2>
      <form name={`enquiry-${slug}`} method="POST" data-netlify="true" class="mt-4 space-y-4">
        <input type="hidden" name="form-name" value={`enquiry-${slug}`} />
        <input type="hidden" name="subject" value={`Life event enquiry: ${page.data.title}`} />

        <label class="block text-sm font-semibold text-stone-900" for="name">Your name</label>
        <input id="name" name="name" required class="w-full rounded-md border-stone-300" />

        <label class="block text-sm font-semibold text-stone-900" for="email">Email address</label>
        <input id="email" name="email" type="email" required class="w-full rounded-md border-stone-300" />

        <label class="block text-sm font-semibold text-stone-900" for="phone">Phone number (optional)</label>
        <input id="phone" name="phone" class="w-full rounded-md border-stone-300" />

        <label class="block text-sm font-semibold text-stone-900" for="message">Tell us about your enquiry</label>
        <textarea id="message" name="message" rows={5} class="w-full rounded-md border-stone-300" required></textarea>

        <button type="submit" class="button-primary">Send enquiry</button>
      </form>
    </article>
  </section>

  <section class="container-width mt-10">
    <article class="card">
      <h2 class="text-3xl">Frequently asked questions</h2>
      <dl class="mt-4 space-y-4">
        {page.data.faqs?.map((faq) => (
          <div>
            <dt class="font-semibold text-stone-900">{faq.question}</dt>
            <dd class="mt-1 text-stone-800">{faq.answer}</dd>
          </div>
        ))}
      </dl>
    </article>
  </section>
</BaseLayout>
