---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const page = await getEntry("pages", "safeguarding");
const safeguarding = await getEntry("safeguarding", "contacts");

if (!page || !safeguarding) throw new Error("Safeguarding content missing.");
const { Content } = await page.render();
---

<BaseLayout title="Safeguarding | St Mary the Virgin, Henbury" description={page.data.intro}>
  <PageHero
    title={page.data.title}
    intro={page.data.intro}
    image="/images/warmemorial.jpg"
    imageAlt="War memorial in St Mary's churchyard"
  />

  <section class="container-width mt-10">
    <article class="card border-l-4 border-l-nave-700">
      <h2 class="text-3xl">Urgent guidance</h2>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-stone-800">
        {safeguarding.data.urgentGuidance.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </section>

  <section class="container-width mt-8 grid gap-6 lg:grid-cols-2">
    <article class="card">
      <h2 class="text-3xl">Local contacts</h2>
      <ul class="mt-4 space-y-4">
        {safeguarding.data.localContacts.map((contact) => (
          <li class="border-b border-stone-200 pb-3 last:border-b-0">
            <p class="font-semibold text-stone-900">{contact.name}</p>
            <p class="text-stone-800">{contact.role}</p>
            {contact.phone && <p class="text-stone-700">{contact.phone}</p>}
            {contact.email && (
              <p>
                <a href={`mailto:${contact.email}`}>{contact.email}</a>
              </p>
            )}
          </li>
        ))}
      </ul>
    </article>

    <article class="card">
      <h2 class="text-3xl">External helplines</h2>
      <ul class="mt-4 space-y-4">
        {safeguarding.data.helplines.map((line) => (
          <li class="border-b border-stone-200 pb-3 last:border-b-0">
            <p class="font-semibold text-stone-900">{line.name}</p>
            {line.phone && <p class="text-stone-800">{line.phone}</p>}
            {line.website && (
              <p>
                <a href={line.website} rel="noreferrer">
                  {line.website}
                </a>
              </p>
            )}
            {line.notes && <p class="text-stone-700">{line.notes}</p>}
          </li>
        ))}
      </ul>
    </article>
  </section>

  <section class="container-width mt-8">
    <article class="card">
      <h2 class="text-3xl">Safeguarding documents</h2>
      <ul class="mt-4 space-y-3">
        {safeguarding.data.documents.map((doc) => (
          <li class="rounded-md border border-stone-200 p-3">
            <p class="font-semibold text-stone-900">
              <a href={doc.file}>{doc.title}</a>
            </p>
            <p class="text-stone-800">{doc.summary}</p>
          </li>
        ))}
      </ul>
      <div class="mt-5 text-stone-800">
        <Content />
      </div>
    </article>
  </section>
</BaseLayout>
