---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const page = await getEntry("pages", "safeguarding");
const safeguarding = await getEntry("safeguarding", "contacts");

if (!page || !safeguarding) throw new Error("Safeguarding content missing.");
const { Content } = await page.render();
---

<BaseLayout title="Safeguarding | St Mary the Virgin, Henbury" description={page.data.intro}>
  <PageHero
    title={page.data.title}
    intro={page.data.intro}
    image="/images/henbury-churchyard-houses.jpg"
    imageAlt="Churchyard graves and neighbouring homes near St Mary's"
  />

  <section class="container-width mt-12">
    <article class="section-rule border-l-2 border-l-nave-700 pl-5">
      <p class="eyebrow">Urgent action</p>
      <h2 class="mt-2 text-4xl">Urgent guidance</h2>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-nave-900">
        {safeguarding.data.urgentGuidance.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </section>

  <section class="container-width mt-12 grid gap-8 lg:grid-cols-2">
    <article class="section-rule">
      <p class="eyebrow">Parish team</p>
      <h2 class="mt-2 text-4xl">Local contacts</h2>
      <ul class="mt-4 space-y-4">
        {safeguarding.data.localContacts.map((contact) => (
          <li class="border-b border-nave-300/45 pb-3 last:border-b-0">
            <p class="font-semibold text-nave-900">{contact.name}</p>
            <p class="text-nave-900">{contact.role}</p>
            {contact.phone && <p class="text-nave-700">{contact.phone}</p>}
            {contact.email && (
              <p>
                <a href={`mailto:${contact.email}`}>{contact.email}</a>
              </p>
            )}
          </li>
        ))}
      </ul>
    </article>

    <article class="section-rule">
      <p class="eyebrow">Independent support</p>
      <h2 class="mt-2 text-4xl">External helplines</h2>
      <ul class="mt-4 space-y-4">
        {safeguarding.data.helplines.map((line) => (
          <li class="border-b border-nave-300/45 pb-3 last:border-b-0">
            <p class="font-semibold text-nave-900">{line.name}</p>
            {line.phone && <p class="text-nave-900">{line.phone}</p>}
            {line.website && (
              <p>
                <a href={line.website} rel="noreferrer">
                  {line.website}
                </a>
              </p>
            )}
            {line.notes && <p class="text-nave-700">{line.notes}</p>}
          </li>
        ))}
      </ul>
    </article>
  </section>

  <section class="container-width mt-12">
    <article class="section-rule">
      <p class="eyebrow">Documents</p>
      <h2 class="mt-2 text-4xl">Safeguarding documents</h2>
      <ul class="mt-4 divide-y divide-nave-300/45 border-y border-nave-300/45">
        {safeguarding.data.documents.map((doc) => (
          <li class="py-3">
            <p class="font-semibold text-nave-900">
              <a href={doc.file}>{doc.title}</a>
            </p>
            <p class="text-nave-900">{doc.summary}</p>
          </li>
        ))}
      </ul>
      <div class="mt-5 text-nave-900">
        <Content />
      </div>
    </article>
  </section>
</BaseLayout>
