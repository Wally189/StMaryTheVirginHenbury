---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const page = await getEntry("pages", "life-events");
if (!page) throw new Error("Missing life events content.");
const { Content } = await page.render();
---

<BaseLayout title="Life Events | St Mary the Virgin, Henbury" description={page.data.intro}>
  <PageHero
    title={page.data.title}
    intro={page.data.intro}
    image="/images/warmemorial.jpg"
    imageAlt="Churchyard memorials at St Mary's"
  />
  <section class="container-width mt-10">
    <ul class="grid gap-4 md:grid-cols-3">
      {
        page.data.cards?.map((card) => (
          <li class="card">
            <h2 class="text-2xl">{card.title}</h2>
            <p class="mt-2 text-stone-800">{card.text}</p>
            {card.linkHref && card.linkText && (
              <p class="mt-4">
                <a href={card.linkHref}>{card.linkText}</a>
              </p>
            )}
          </li>
        ))
      }
    </ul>
  </section>
  <section class="container-width mt-8">
    <div class="card text-stone-800">
      <Content />
    </div>
  </section>
</BaseLayout>
