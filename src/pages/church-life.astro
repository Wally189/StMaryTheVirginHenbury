---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const page = await getEntry("pages", "church-life");
if (!page) throw new Error("Missing church life content.");
const { Content } = await page.render();
---

<BaseLayout title="Church Life | St Mary the Virgin, Henbury" description={page.data.intro}>
  <PageHero
    title={page.data.title}
    intro={page.data.intro}
    image="/images/StMarys2.jpg"
    imageAlt="View of church pews and aisle at St Mary's"
  />
  <section class="container-width mt-10">
    <ul class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        page.data.cards?.map((card) => (
          <li class="card">
            <h2 class="text-2xl">{card.title}</h2>
            <p class="mt-2 text-stone-800">{card.text}</p>
          </li>
        ))
      }
    </ul>
  </section>
  <section class="container-width mt-8">
    <div class="card text-stone-800">
      <Content />
    </div>
  </section>
</BaseLayout>
