---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const page = await getEntry("pages", "contact");
if (!page) throw new Error("Missing contact page content.");
const { Content } = await page.render();
---

<BaseLayout title="Contact | St Mary the Virgin, Henbury" description={page.data.intro}>
  <PageHero
    title={page.data.title}
    intro={page.data.intro}
    image="/images/StMarys.jpg"
    imageAlt="St Mary the Virgin church exterior"
  />

  <section class="container-width mt-10 grid gap-8 lg:grid-cols-[1fr_1fr]">
    <article class="card">
      <h2 class="text-3xl">Parish office</h2>
      <p class="mt-2 text-stone-800">Church Lane, Henbury, Bristol BS10 7QF</p>
      <p class="mt-1 text-stone-800">Phone: 0117 950 8644</p>
      <p class="mt-1 text-stone-800">
        Email: <a href="mailto:office@stmaryhenbury.org.uk">office@stmaryhenbury.org.uk</a>
      </p>
      <p class="mt-2 text-stone-700">Office hours: Tuesday to Friday, 9.30am to 1.30pm</p>
      <p class="mt-2 text-stone-700">
        Social:
        <a href="https://www.facebook.com" rel="noreferrer">Facebook</a>
        |
        <a href="https://www.instagram.com" rel="noreferrer">Instagram</a>
      </p>
      <div class="mt-4 text-stone-800">
        <Content />
      </div>
    </article>

    <article class="card">
      <h2 class="text-3xl">Send a message</h2>
      <form name="contact" method="POST" data-netlify="true" class="mt-4 space-y-4">
        <input type="hidden" name="form-name" value="contact" />

        <label class="block text-sm font-semibold text-stone-900" for="contact-name">Name</label>
        <input id="contact-name" name="name" class="w-full rounded-md border-stone-300" required />

        <label class="block text-sm font-semibold text-stone-900" for="contact-email">Email</label>
        <input id="contact-email" name="email" type="email" class="w-full rounded-md border-stone-300" required />

        <label class="block text-sm font-semibold text-stone-900" for="contact-subject">Subject</label>
        <input id="contact-subject" name="subject" class="w-full rounded-md border-stone-300" required />

        <label class="block text-sm font-semibold text-stone-900" for="contact-message">Message</label>
        <textarea id="contact-message" name="message" rows={5} class="w-full rounded-md border-stone-300" required></textarea>

        <button type="submit" class="button-primary">Send message</button>
      </form>

      <h3 class="mt-8 text-2xl">Newsletter signup</h3>
      <form name="newsletter" method="POST" data-netlify="true" class="mt-3 space-y-3">
        <input type="hidden" name="form-name" value="newsletter" />
        <label class="block text-sm font-semibold text-stone-900" for="newsletter-email">Email address</label>
        <input id="newsletter-email" name="email" type="email" class="w-full rounded-md border-stone-300" required />
        <button type="submit" class="button-secondary">Join newsletter list</button>
      </form>
    </article>
  </section>

  <section class="container-width mt-8">
    <article class="card">
      <h2 class="text-3xl">Find us</h2>
      <div class="mt-4 overflow-hidden rounded-md border border-stone-200">
        <iframe
          title="Map showing St Mary the Virgin, Henbury"
          src="https://www.google.com/maps?q=St+Mary+the+Virgin+Henbury+Bristol&output=embed"
          width="100%"
          height="360"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </article>
  </section>
</BaseLayout>
