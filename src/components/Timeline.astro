---
interface TimelineEntry {
  era: string;
  title: string;
  summary: string;
}

interface Props {
  entries: TimelineEntry[];
}

const { entries } = Astro.props;
---

<ol class="relative border-l border-nave-300 pl-6">
  {
    entries.map((entry) => (
      <li class="mb-8">
        <div class="absolute -left-[4px] mt-2 h-2 w-2 rounded-full bg-nave-700"></div>
        <p class="eyebrow">{entry.era}</p>
        <h3 class="mt-1 text-2xl">{entry.title}</h3>
        <p class="mt-2 text-nave-900">{entry.summary}</p>
      </li>
    ))
  }
</ol>
