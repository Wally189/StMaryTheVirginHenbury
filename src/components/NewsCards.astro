---
import { formatDateNoWeekday } from "../utils/dates";

interface Item {
  id: string;
  slug: string;
  data: {
    title: string;
    summary: string;
    date: Date;
    category: string;
  };
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<ul class="divide-y divide-nave-300/45 border-y border-nave-300/45">
  {
    items.map((item) => (
      <li class="grid gap-3 py-5 md:grid-cols-[0.24fr_0.76fr] md:items-start">
        <p class="eyebrow">{formatDateNoWeekday(item.data.date)} | {item.data.category}</p>
        <div>
          <h3 class="text-2xl">{item.data.title}</h3>
          <p class="mt-2 text-nave-900">{item.data.summary}</p>
          <p class="mt-2">
          <a href={`/news/${item.slug}`}>Read more</a>
        </p>
        </div>
      </li>
    ))
  }
</ul>
