---
const links = [
  { href: "/welcome", label: "Welcome" },
  { href: "/services-events", label: "Services & Events" },
  { href: "/church-life", label: "Church Life" },
  { href: "/life-events", label: "Baptisms, Weddings & Funerals" },
  { href: "/whos-who", label: "Parish Team" },
  { href: "/contact", label: "Get in touch" },
  { href: "/history", label: "A Fascinating History" },
  { href: "/fundraising", label: "Fundraising" },
  { href: "/safeguarding", label: "Safeguarding" },
  { href: "/easter", label: "Easter at St Mary's" },
  { href: "/christmas", label: "Christmas at St Mary's" },
];

const isCurrentPath = (href: string) =>
  Astro.url.pathname === href || Astro.url.pathname.startsWith(`${href}/`);
---

<header class="border-b border-nave-300/55 bg-stone-100">
  <div class="container-width border-b border-nave-300/55 py-3 text-xs font-semibold uppercase tracking-[0.12em] text-nave-700">
    Sunday 10.00am Parish Eucharist | Everyone welcome
  </div>
  <div class="container-width flex items-center justify-between py-5">
    <a class="no-underline focus-visible:ring-offset-stone-100" href="/">
      <div class="flex items-center gap-3">
        <img
          src="/images/logo.jpg"
          alt="St Mary the Virgin, Henbury crest"
          class="h-11 w-11 rounded-full border border-nave-300 object-cover"
          loading="eager"
          width="48"
          height="48"
        />
        <div>
          <p class="font-body text-lg font-semibold uppercase tracking-[0.16em] text-nave-900">St Mary the Virgin</p>
          <p class="text-xs uppercase tracking-[0.12em] text-nave-700">Henbury, Bristol</p>
        </div>
      </div>
    </a>
    <nav class="hidden flex-wrap gap-x-5 gap-y-2 lg:flex" aria-label="Primary">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "border-b border-transparent pb-1 text-xs font-semibold uppercase tracking-[0.11em] no-underline",
              isCurrentPath(link.href)
                ? "border-nave-700 text-nave-900"
                : "text-nave-700 hover:border-nave-500 hover:text-nave-900",
            ]}
            aria-current={isCurrentPath(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
    <details class="lg:hidden">
      <summary class="cursor-pointer rounded-sm border border-nave-300 px-3 py-2 text-xs font-semibold uppercase tracking-[0.11em] text-nave-900">
        Menu
      </summary>
      <nav class="absolute right-4 z-30 mt-2 w-72 border border-nave-300 bg-stone-50 p-3" aria-label="Mobile">
        <ul class="space-y-2">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    "block rounded-sm px-2 py-2 text-xs font-semibold uppercase tracking-[0.11em] no-underline",
                    isCurrentPath(link.href) ? "bg-nave-100 text-nave-900" : "text-nave-900 hover:bg-stone-100",
                  ]}
                  aria-current={isCurrentPath(link.href) ? "page" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </details>
  </div>
</header>
