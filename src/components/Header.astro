---
const links = [
  { href: "/welcome", label: "Welcome" },
  { href: "/services-events", label: "Services & Events" },
  { href: "/church-life", label: "Church Life" },
  { href: "/life-events", label: "Life Events" },
  { href: "/history", label: "History" },
  { href: "/safeguarding", label: "Safeguarding" },
  { href: "/contact", label: "Contact" },
];

const isCurrentPath = (href: string) =>
  Astro.url.pathname === href || Astro.url.pathname.startsWith(`${href}/`);
---

<header class="border-b border-stone-200 bg-stone-100">
  <div class="container-width py-3 text-sm text-stone-700">
    Sunday 10.00am Parish Eucharist | Everyone is welcome
  </div>
  <div class="container-width flex items-center justify-between py-4">
    <a class="no-underline focus-visible:ring-offset-stone-100" href="/">
      <div class="flex items-center gap-3">
        <img
          src="/images/logo.jpg"
          alt="St Mary the Virgin, Henbury crest"
          class="h-12 w-12 rounded-full border border-stone-300 object-cover"
          loading="eager"
          width="48"
          height="48"
        />
        <div>
          <p class="font-heading text-2xl leading-none text-stone-900">St Mary the Virgin</p>
          <p class="text-sm text-stone-700">Henbury, Bristol</p>
        </div>
      </div>
    </a>
    <nav class="hidden gap-6 md:flex" aria-label="Primary">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "text-sm font-semibold no-underline",
              isCurrentPath(link.href)
                ? "text-nave-900 underline decoration-2"
                : "text-stone-800 hover:text-nave-900",
            ]}
            aria-current={isCurrentPath(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
    <details class="md:hidden">
      <summary class="cursor-pointer rounded-md border border-stone-300 px-3 py-2 text-sm font-semibold text-stone-900">
        Menu
      </summary>
      <nav class="absolute right-4 z-30 mt-2 w-64 rounded-lg border border-stone-200 bg-white p-3 shadow-card" aria-label="Mobile">
        <ul class="space-y-2">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    "block rounded px-2 py-2 text-sm no-underline",
                    isCurrentPath(link.href) ? "bg-harbour-100 font-semibold text-harbour-900" : "text-stone-900 hover:bg-stone-100",
                  ]}
                  aria-current={isCurrentPath(link.href) ? "page" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </details>
  </div>
</header>
