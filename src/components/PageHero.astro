---
interface Props {
  title: string;
  intro: string;
  image: string;
  imageAlt: string;
}

const { title, intro, image, imageAlt } = Astro.props;
---

<section class="relative overflow-hidden border-b border-nave-300/55 bg-stone-100">
  <div class="container-width py-14">
    <p class="eyebrow">Parish information</p>
    <div class="mt-4 grid gap-8 md:grid-cols-[0.56fr_0.44fr] md:items-start">
      <h1 class="section-title">{title}</h1>
      <p class="max-w-xl text-lg text-nave-900">{intro}</p>
    </div>
  </div>
  <div class="container-width border-t border-nave-300/55 pb-8 pt-6">
    <img
      src={image}
      alt={imageAlt}
      class="aspect-[18/7] w-full border border-nave-300/70 object-cover"
      loading="lazy"
      width="1600"
      height="620"
    />
  </div>
</section>
