---
interface Props {
  title: string;
  intro: string;
  image: string;
  imageAlt: string;
}

const { title, intro, image, imageAlt } = Astro.props;
---

<section class="relative overflow-hidden border-b border-stone-200 bg-stone-100">
  <div class="container-width grid gap-6 py-10 md:grid-cols-[1.2fr_1fr] md:items-center">
    <div>
      <h1 class="text-4xl md:text-5xl">{title}</h1>
      <p class="mt-4 max-w-2xl text-lg text-stone-800">{intro}</p>
    </div>
    <img
      src={image}
      alt={imageAlt}
      class="h-64 w-full rounded-lg border border-stone-300 object-cover shadow-card"
      loading="lazy"
      width="640"
      height="400"
    />
  </div>
</section>
