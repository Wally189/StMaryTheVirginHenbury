---
import { formatDate } from "../utils/dates";

interface Item {
  id: string;
  slug: string;
  data: {
    title: string;
    summary: string;
    start: Date;
    time: string;
    location: string;
    category: string;
  };
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<ul class="divide-y divide-nave-300/45 border-y border-nave-300/45">
  {
    items.map((item) => (
      <li class="grid gap-3 py-5 md:grid-cols-[0.24fr_0.76fr] md:items-start">
        <p class="eyebrow">{formatDate(item.data.start)} | {item.data.time}</p>
        <div>
          <h3 class="text-2xl">{item.data.title}</h3>
          <p class="mt-1 text-sm font-semibold uppercase tracking-[0.11em] text-harbour-900">{item.data.category}</p>
          <p class="mt-2 text-nave-900">{item.data.summary}</p>
          <p class="mt-1 text-sm text-nave-700">{item.data.location}</p>
          <p class="mt-2">
          <a href={`/events/${item.slug}`}>Event details</a>
        </p>
        </div>
      </li>
    ))
  }
</ul>
